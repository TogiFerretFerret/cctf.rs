# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Postgres connection string
DATABASE_URL=postgres://cctf:cctf@localhost:5432/cctf

# Auth signing key — MUST be >= 32 bytes. Generate one:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-32+-random-bytes-aaaaaaaaaaaaaaaa

# Where the HTTP server listens
BIND_ADDR=0.0.0.0:8080

# Only set to 1 if you actually run behind a trusted reverse proxy that sets
# X-Forwarded-For. Otherwise leave unset so rate limiting uses the real peer IP.
# TRUST_PROXY_HEADERS=1

# CTFtime OAuth (optional for local dev — leave blank to disable that login path)
CTFTIME_CLIENT_ID=
CTFTIME_CLIENT_SECRET=
CTFTIME_REDIRECT_URI=
