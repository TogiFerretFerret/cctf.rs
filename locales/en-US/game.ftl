# Game State
game-not-started = The competition has not started yet. Starts in {$time_left}.
game-paused = The competition is currently paused by administrators. Solves are temporarily disabled.
game-ended = The competition has ended! The scoreboard is now locked.
game-freeze-warning = The scoreboard is now frozen! Solves will still be validated, but the public standings are locked until the closing ceremony.

# Ticket / Support System
ticket-created = Support ticket #{$id} opened successfully. An admin will assist you shortly.
ticket-closed = Support ticket #{$id} has been resolved and closed.
